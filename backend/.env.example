APP_NAME=AI Campus Recruit Platform
CORS_ORIGINS=*
DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/campus_recruit?charset=utf8mb4
REDIS_URL=redis://127.0.0.1:6379/0
JWT_SECRET_KEY=please-change-this-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- LLM API (OpenAI-compatible, supports DeepSeek / Moonshot / etc.) ---
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo

# --- Local Embedding Model (auto-downloaded on first use, ~130MB) ---
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --- RAG Settings ---
RAG_CHUNK_SIZE=400
RAG_CHUNK_OVERLAP=80
RAG_TOP_K=5
